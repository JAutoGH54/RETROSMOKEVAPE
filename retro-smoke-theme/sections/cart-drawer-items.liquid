{% comment %}
  This section is rendered dynamically via the Section Rendering API 
  when items are added, removed, or updated in the cart drawer.
{% endcomment %}

<div class="drawer-items-wrapper">
  {% if cart.item_count > 0 %}
    
    <div class="drawer-items-list">
      {% for item in cart.items %}
        <div class="drawer-item" data-line-item-id="{{ item.id }}">
          
          <div class="drawer-item-image-box">
            {% if item.image != blank %}
              <img src="{{ item.image | image_url: width: 160, height: 160, crop: 'center' }}" 
                   alt="{{ item.title | escape }}" 
                   class="drawer-item-img"
                   width="80"
                   height="80">
            {% else %}
              <div class="drawer-item-placeholder">📦</div>
            {% endif %}
          </div>

          <div class="drawer-item-details">
            <span class="drawer-item-vendor">{{ item.vendor }}</span>
            <h4 class="drawer-item-title"><a href="{{ item.url }}">{{ item.product.title }}</a></h4>
            
            {% unless item.product.has_only_default_variant %}
              <p class="drawer-item-variant">{{ item.variant.title }}</p>
            {% endunless %}

            <div class="drawer-item-price-qty-row">
              <!-- Price display -->
              <div class="drawer-item-price">
                {% if item.original_line_price != item.final_line_price %}
                  <span class="drawer-price-sale">{{ item.final_price | money }}</span>
                  <span class="drawer-price-compare">{{ item.original_price | money }}</span>
                {% else %}
                  <span>{{ item.final_price | money }}</span>
                {% endif %}
              </div>

              <!-- Qty control -->
              <div class="drawer-qty-selector">
                <button class="qty-btn qty-minus" type="button">—</button>
                <input type="number" 
                       class="qty-input drawer-qty-input" 
                       value="{{ item.quantity }}" 
                       min="0" 
                       data-line="{{ forloop.index }}"
                       aria-label="Item Quantity">
                <button class="qty-btn qty-plus" type="button">+</button>
              </div>
            </div>

            <!-- Remove link -->
            <a href="#" class="drawer-item-remove" data-line="{{ forloop.index }}">Remove</a>

          </div>

        </div>
      {% endfor %}
    </div>

    <!-- Drawer Footer / Summary -->
    <div class="drawer-summary">
      <div class="drawer-subtotal-row">
        <span class="subtotal-label">Subtotal</span>
        <span class="subtotal-value">{{ cart.total_price | money }}</span>
      </div>
      
      <p class="drawer-shipping-disclaimer">
        Taxes and shipping are calculated at checkout.
      </p>

      <div class="drawer-action-buttons">
        <form action="/cart" method="post" class="drawer-checkout-form">
          <input type="submit" name="checkout" class="btn btn-primary drawer-btn-checkout" value="Proceed to Checkout">
        </form>
        <a href="/cart" class="btn btn-secondary drawer-btn-cart">View Full Cart</a>
      </div>
    </div>

  {% else %}
    
    <!-- Empty Cart State -->
    <div class="drawer-empty-state">
      <div class="empty-icon">🛒</div>
      <h4>Your cart is empty</h4>
      <p>Browse our catalog to find hardware, accessories, and quality gear.</p>
      <a href="/collections/all" class="btn btn-primary empty-shop-btn">Start Shopping</a>
    </div>

  {% endif %}
</div>

{% stylesheet %}
  .drawer-items-wrapper {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .drawer-items-list {
    flex-grow: 1;
    overflow-y: auto;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .drawer-item {
    display: flex;
    gap: 1rem;
    border-bottom: 1px solid var(--color-brand-border);
    padding-bottom: 1.25rem;
  }

  .drawer-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .drawer-item-image-box {
    width: 80px;
    height: 80px;
    background-color: var(--color-brand-charcoal-light);
    border: 1px solid rgba(230, 209, 172, 0.05);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }

  .drawer-item-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0.25rem;
  }

  .drawer-item-placeholder {
    font-size: 1.5rem;
    color: #6d6b65;
  }

  .drawer-item-details {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .drawer-item-vendor {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--color-brand-coral);
    font-family: var(--font-heading);
    font-weight: 700;
  }

  .drawer-item-title {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-brand-cream);
  }

  .drawer-item-title a:hover {
    color: var(--color-brand-coral);
  }

  .drawer-item-variant {
    font-size: 0.75rem;
    color: #8c8982;
  }

  .drawer-item-price-qty-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.5rem;
  }

  .drawer-item-price {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-brand-cream);
  }

  .drawer-price-sale {
    color: var(--color-brand-coral);
  }

  .drawer-price-compare {
    font-size: 0.75rem;
    text-decoration: line-through;
    color: #6d6b65;
    margin-left: 0.35rem;
  }

  /* Quantity buttons inside drawer */
  .drawer-qty-selector {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(230, 209, 172, 0.15);
    border-radius: 4px;
    overflow: hidden;
    height: 30px;
    background-color: var(--color-brand-charcoal-light);
  }

  .drawer-qty-selector .qty-btn {
    background: none;
    border: none;
    color: var(--color-brand-cream);
    width: 26px;
    height: 100%;
    cursor: pointer;
    font-size: 0.7rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s;
  }

  .drawer-qty-selector .qty-btn:hover {
    background-color: rgba(230, 209, 172, 0.05);
  }

  .drawer-qty-selector input.drawer-qty-input {
    width: 32px;
    height: 100%;
    border: none;
    background: none;
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-brand-cream);
    padding: 0;
  }

  .drawer-qty-selector input[type=number]::-webkit-inner-spin-button, 
  .drawer-qty-selector input[type=number]::-webkit-outer-spin-button { 
    -webkit-appearance: none; 
    margin: 0; 
  }

  .drawer-item-remove {
    font-size: 0.75rem;
    color: #6d6b65;
    text-decoration: underline;
    margin-top: 0.35rem;
    width: fit-content;
  }

  .drawer-item-remove:hover {
    color: var(--color-brand-coral);
  }

  /* Drawer Summary Area */
  .drawer-summary {
    border-top: 1px solid var(--color-brand-border);
    padding: 1.5rem;
    background-color: #0b0b0c;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .drawer-subtotal-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .subtotal-label {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-brand-cream);
  }

  .subtotal-value {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-brand-coral);
  }

  .drawer-shipping-disclaimer {
    font-size: 0.75rem;
    color: #6d6b65;
    line-height: 1.4;
    text-align: center;
  }

  .drawer-action-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .drawer-checkout-form {
    width: 100%;
  }

  .drawer-btn-checkout {
    width: 100%;
    padding: 1rem;
  }

  .drawer-btn-cart {
    width: 100%;
    padding: 0.85rem;
    border-color: rgba(230, 209, 172, 0.15);
  }

  /* Empty state */
  .drawer-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    text-align: center;
    gap: 1rem;
    margin: auto 0;
  }

  .empty-icon {
    font-size: 3rem;
    opacity: 0.25;
  }

  .drawer-empty-state h4 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    text-transform: uppercase;
    color: var(--color-brand-cream);
  }

  .drawer-empty-state p {
    font-size: 0.85rem;
    color: #8c8982;
    line-height: 1.5;
  }

  .empty-shop-btn {
    width: 100%;
    margin-top: 0.5rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Cart Drawer Items",
  "settings": []
}
{% endschema %}
