<div class="hero-section-wrapper" 
     style="background-image: url('{% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 1800 }}{% else %}{{ 'hero-bg.png' | asset_url }}{% endif %}');">
  
  <div class="hero-overlay" style="background-color: rgba(15, 15, 16, {{ section.settings.overlay_opacity | default: 50 | divided_by: 100.0 }});"></div>

  <div class="hero-vapor-canvas-wrapper">
    <canvas id="hero-vapor-canvas"></canvas>
  </div>

  <div class="hero-content-container animate-fade-in">
    <div class="hero-text-block">
      <span class="hero-badge">{{ section.settings.badge_text | default: "ESTABLISHED LOCAL SHOP ONLINE" }}</span>
      <h1 class="hero-title">
        {{ section.settings.heading | default: "RETRO STYLE. PREMIUM GEAR." }}
      </h1>
      <p class="hero-subtitle">
        {{ section.settings.subheading | default: "Retro vibe, quality hardware, and trusted local service delivered right to your door." }}
      </p>
      
      <div class="hero-cta-buttons">
        <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="btn btn-primary hero-btn">
          {{ section.settings.button_text | default: "Shop the Catalog" }}
        </a>
        <a href="#shop-by-category" class="btn btn-secondary hero-btn-secondary">
          Browse Categories
        </a>
      </div>
    </div>
  </div>

  <!-- Decorative bottom glow -->
  <div class="hero-bottom-glow"></div>
</div>

{% stylesheet %}
  .hero-section-wrapper {
    position: relative;
    width: 100%;
    min-height: 80vh;
    display: flex;
    align-items: center;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }

  .hero-content-container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 6rem var(--page-margin);
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .hero-text-block {
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-badge {
    color: var(--color-brand-coral);
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    animation: fadeIn 0.8s ease-out;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--color-brand-cream);
    text-shadow: 0 4px 20px rgba(0,0,0,0.6);
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 4.25rem;
    }
  }

  .hero-subtitle {
    font-size: 1.2rem;
    line-height: 1.6;
    color: #e5e2da;
    max-width: 580px;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
  }

  .hero-cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1rem;
  }

  .hero-btn {
    padding: 1.1rem 2.25rem;
    font-size: 1rem;
  }

  .hero-btn-secondary {
    padding: 1.1rem 2.25rem;
    font-size: 1rem;
    border-color: rgba(250, 248, 245, 0.4);
    background-color: rgba(15, 15, 16, 0.4);
  }

  .hero-bottom-glow {
    position: absolute;
    bottom: -150px;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 300px;
    background-color: rgba(255, 107, 74, 0.06);
    filter: blur(120px);
    pointer-events: none;
    border-radius: 50%;
    z-index: 1;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 10,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Overlay Darkening",
      "default": 50
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Established Local Shop Online"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "Retro Style. Premium Gear."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading Text",
      "default": "Retro vibe, quality hardware, and trusted local service delivered right to your door."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Label",
      "default": "Shop the Catalog"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Retro Hero Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}
