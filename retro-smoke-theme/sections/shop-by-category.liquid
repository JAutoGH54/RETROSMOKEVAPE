{% stylesheet %}
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.85rem;
    max-width: var(--page-width);
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .categories-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 992px) {
    .categories-grid {
      grid-template-columns: repeat(6, 1fr);
      gap: 1rem;
    }
  }

  .category-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .category-card-image-link {
    display: block;
    width: 100%;
  }

  .category-card-image-box {
    position: relative;
    width: 100%;
    padding-top: 80%; /* Sleek wide aspect ratio (less tall) */
    overflow: hidden;
    background-color: #0b0b0c;
    border-bottom: 1.5px solid rgba(230, 209, 172, 0.05);
  }

  .category-card-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .category-card-info {
    padding: 0.85rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background-color: rgba(28, 28, 30, 0.25);
    flex-grow: 1;
  }

  .category-card-title-link {
    text-decoration: none;
    display: inline-block;
  }

  .category-card-title {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--color-brand-cream);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    transition: color 0.2s;
  }

  .category-card-title-link:hover .category-card-title {
    color: var(--color-brand-coral);
  }

  /* Subcategory micro-pills */
  .category-sub-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.25rem;
  }

  .sub-pill {
    font-size: 0.68rem;
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    color: #b3b0a8;
    background-color: rgba(230, 209, 172, 0.05);
    border: 1px solid rgba(230, 209, 172, 0.12);
    padding: 0.35rem 0.65rem;
    border-radius: 16px;
    text-decoration: none;
    transition: all 0.2s ease;
    display: inline-block;
  }

  .sub-pill:hover {
    color: var(--color-brand-charcoal);
    background-color: var(--color-brand-green);
    border-color: var(--color-brand-green);
    box-shadow: 0 0 8px rgba(36, 168, 104, 0.4);
  }

  /* Hover states */
  .category-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-brand-coral);
    box-shadow: 0 10px 25px rgba(226, 108, 62, 0.12);
  }

  .category-card:hover .category-card-img {
    transform: scale(1.06);
  }
{% endstylesheet %}

