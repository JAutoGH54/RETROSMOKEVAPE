<div class="featured-products-section section-spacing">
  <div class="section-header reveal-on-scroll">
    <h2>{{ section.settings.heading | default: "New Arrivals" }}</h2>
    <p>{{ section.settings.subheading | default: "Grab the latest authentic hardware and accessories in our lineup." }}</p>
  </div>

  <div class="products-grid">
    {% assign selected_collection = collections[section.settings.collection] %}
    
    {% if selected_collection != blank and selected_collection.products_count > 0 %}
      
      <!-- [SHOPIFY DYNAMIC PRODUCT LOOP START] -->
      {% for product in selected_collection.products limit: section.settings.product_limit %}
        {% assign loop_index_mod = forloop.index0 | modulo: 4 %}
        {% assign delay_class = "" %}
        {% if loop_index_mod == 1 %}{% assign delay_class = "delay-100" %}
        {% elsif loop_index_mod == 2 %}{% assign delay_class = "delay-200" %}
        {% elsif loop_index_mod == 3 %}{% assign delay_class = "delay-300" %}{% endif %}
        
        <div class="product-card glass-panel reveal-on-scroll {{ delay_class }}">
          
          <div class="product-card-image-wrapper">
            <a href="{{ product.url }}" class="product-card-image-link">
              {% if product.featured_image != blank %}
                <img src="{{ product.featured_image | image_url: width: 360, height: 360, crop: 'center' }}" 
                     alt="{{ product.title | escape }}" 
                     class="product-card-img"
                     width="300"
                     height="300"
                     loading="lazy">
              {% else %}
                <div class="product-card-placeholder-img">📦</div>
              {% endif %}
            </a>

            <!-- Badges -->
            <div class="product-card-badges">
              {% if product.compare_at_price > product.price %}
                <span class="badge badge-sale">Sale</span>
              {% endif %}
              
              {% for tag in product.tags %}
                {% if tag == 'new' or tag == 'New' %}
                  <span class="badge badge-new">New</span>
                {% endif %}
              {% endfor %}
            </div>
          </div>

          <div class="product-card-content">
            <span class="product-card-vendor">{{ product.vendor }}</span>
            <h3 class="product-card-title">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h3>
            
            {% assign color_option_index = -1 %}
            {% for option in product.options_with_values %}
              {% assign downcased_option_name = option.name | downcase %}
              {% if downcased_option_name contains 'color' or downcased_option_name contains 'colour' or downcased_option_name contains 'style' %}
                {% assign color_option_index = forloop.index0 %}
                {% break %}
              {% endif %}
            {% endfor %}

            <div class="product-card-swatches">
              {% if color_option_index != -1 %}
                {% assign color_option = product.options_with_values[color_option_index] %}
                {% for value in color_option.values %}
                  {% assign variant_to_use = blank %}
                  {% for variant in product.variants %}
                    {% assign option_value = variant.options[color_option_index] %}
                    {% if option_value == value %}
                      {% assign variant_to_use = variant %}
                      {% break %}
                    {% endif %}
                  {% endfor %}
                  
                  {% if variant_to_use != blank %}
                    {% assign variant_img = variant_to_use.image | default: product.featured_image %}
                    {% assign variant_img_url = variant_img | image_url: width: 360, height: 360, crop: 'center' %}
                    <span class="swatch-color{% if forloop.first %} active{% endif %}" 
                          style="background-color: {{ value | split: ' ' | last | downcase }};" 
                          data-image="{{ variant_img_url }}" 
                          data-price="{{ variant_to_use.price | money }}"
                          data-compare-price="{% if variant_to_use.compare_at_price > variant_to_use.price %}{{ variant_to_use.compare_at_price | money }}{% endif %}"
                          data-variant-id="{{ variant_to_use.id }}"
                          title="{{ value | escape }}">
                    </span>
                  {% endif %}
                {% endfor %}
              {% endif %}
            </div>

            <div class="product-card-price-row">
              {% if product.compare_at_price > product.price %}
                <span class="product-price price-sale">{{ product.price | money }}</span>
                <span class="product-compare-price">{{ product.compare_at_price | money }}</span>
              {% else %}
                <span class="product-price">{{ product.price | money }}</span>
              {% endif %}
            </div>

            <!-- In-stock indicator -->
            <div class="product-stock-status">
              {% if product.available %}
                <span class="stock-dot stock-in"></span> <span class="stock-text">In Stock</span>
              {% else %}
                <span class="stock-dot stock-out"></span> <span class="stock-text">Out of Stock</span>
              {% endif %}
            </div>

            <!-- Add to Cart Form -->
            <div class="product-card-actions">
              {% if product.available %}
                <form action="/cart/add" method="post" enctype="multipart/form-data" class="product-card-add-form">
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" class="btn btn-primary product-card-btn">Add To Cart</button>
                </form>
              {% else %}
                <button class="btn btn-secondary product-card-btn" disabled>Sold Out</button>
              {% endif %}
            </div>

          </div>

        </div>
      {% endfor %}
      <!-- [SHOPIFY DYNAMIC PRODUCT LOOP END] -->

    {% else %}
      
      <!-- [FALLBACK MOCK CARDS START] - Shown only when collection is empty or not configured -->
      {% assign mock_names = "Lookah Seahorse Pro Plus, Yocan Uni Pro 2.0, Pax Plus Vaporizer, Storz & Bickel Mighty+" | split: ", " %}
      {% assign mock_vendors = "Lookah, Yocan, PAX, Storz & Bickel" | split: ", " %}
      {% assign mock_prices = "$49.99, $39.99, $249.99, $399.00" | split: ", " %}
      {% assign mock_compare_prices = "$59.99, $49.99, $299.99, $399.00" | split: ", " %}
      {% assign mock_badges = "sale, new, sale, none" | split: ", " %}
      {% assign mock_emojis = "💨, 🔋, ☘️, ⚙️" | split: ", " %}
      {% assign mock_delays = ", delay-100, delay-200, delay-300" | split: ", " %}

      {% for i in (0..3) %}
        <div class="product-card glass-panel reveal-on-scroll {{ mock_delays[i] }}">
          <div class="product-card-image-wrapper">
            <div class="product-card-placeholder-img" style="background-image: linear-gradient(135deg, #1c1c1e 0%, #151516 100%);">
              <span style="font-size: 3.5rem;">{{ mock_emojis[i] }}</span>
            </div>
            <div class="product-card-badges">
              {% if mock_badges[i] == 'sale' %}
                <span class="badge badge-sale">Sale</span>
              {% elsif mock_badges[i] == 'new' %}
                <span class="badge badge-new">New</span>
              {% endif %}
            </div>
          </div>

          <div class="product-card-content">
            <span class="product-card-vendor">{{ mock_vendors[i] }}</span>
            <h3 class="product-card-title">
              <a href="#" onclick="return false;">{{ mock_names[i] }}</a>
            </h3>
            
            <div class="product-card-swatches">
              {% if i == 0 %}
                <span class="swatch-color active" style="background-color: #5a5a5a;" data-emoji="💨" data-bg="linear-gradient(135deg, #5a5a5a 0%, #1c1c1e 100%)" data-price="$49.99" data-compare-price="$59.99" data-variant-id="4418302000000" title="Slate Grey"></span>
                <span class="swatch-color" style="background-color: #1e3a8a;" data-emoji="🌊" data-bg="linear-gradient(135deg, #1e3a8a 0%, #1c1c1e 100%)" data-price="$49.99" data-compare-price="$59.99" data-variant-id="4418302000001" title="Royal Blue"></span>
                <span class="swatch-color" style="background-color: #E26C3E;" data-emoji="🔥" data-bg="linear-gradient(135deg, #E26C3E 0%, #1c1c1e 100%)" data-price="$54.99" data-compare-price="$64.99" data-variant-id="4418302000002" title="Sunset Coral"></span>
              {% elsif i == 1 %}
                <span class="swatch-color active" style="background-color: #E6D1AC;" data-emoji="🔋" data-bg="linear-gradient(135deg, #E6D1AC 0%, #1c1c1e 100%)" data-price="$39.99" data-compare-price="$49.99" data-variant-id="4418302000010" title="Retro Cream"></span>
                <span class="swatch-color" style="background-color: #2d2d30;" data-emoji="🔌" data-bg="linear-gradient(135deg, #2d2d30 0%, #1c1c1e 100%)" data-price="$39.99" data-compare-price="$49.99" data-variant-id="4418302000011" title="Matte Black"></span>
                <span class="swatch-color" style="background-color: #d4af37;" data-emoji="👑" data-bg="linear-gradient(135deg, #d4af37 0%, #1c1c1e 100%)" data-price="$44.99" data-compare-price="$54.99" data-variant-id="4418302000012" title="Champagne Gold"></span>
              {% elsif i == 2 %}
                <span class="swatch-color active" style="background-color: #9ca998;" data-emoji="☘️" data-bg="linear-gradient(135deg, #9ca998 0%, #1c1c1e 100%)" data-price="$249.99" data-compare-price="$299.99" data-variant-id="4418302000020" title="Sage"></span>
                <span class="swatch-color" style="background-color: #1f1f1f;" data-emoji="🌑" data-bg="linear-gradient(135deg, #1f1f1f 0%, #1c1c1e 100%)" data-price="$249.99" data-compare-price="$299.99" data-variant-id="4418302000021" title="Onyx Black"></span>
                <span class="swatch-color" style="background-color: #ccccff;" data-emoji="🔮" data-bg="linear-gradient(135deg, #ccccff 0%, #1c1c1e 100%)" data-price="$259.99" data-compare-price="$309.99" data-variant-id="4418302000022" title="Periwinkle"></span>
              {% elsif i == 3 %}
                <span class="swatch-color active" style="background-color: #121212;" data-emoji="⚙️" data-bg="linear-gradient(135deg, #121212 0%, #1c1c1e 100%)" data-price="$399.00" data-compare-price="$399.00" data-variant-id="4418302000030" title="Stealth Black"></span>
                <span class="swatch-color" style="background-color: #ff8c00;" data-emoji="⚡" data-bg="linear-gradient(135deg, #ff8c00 0%, #1c1c1e 100%)" data-price="$419.00" data-compare-price="$449.00" data-variant-id="4418302000031" title="Hazard Orange"></span>
              {% endif %}
            </div>

            <div class="product-card-price-row">
              {% if mock_badges[i] == 'sale' %}
                <span class="product-price price-sale">{{ mock_prices[i] }}</span>
                <span class="product-compare-price">{{ mock_compare_prices[i] }}</span>
              {% else %}
                <span class="product-price">{{ mock_prices[i] }}</span>
              {% endif %}
            </div>

            <div class="product-stock-status">
              <span class="stock-dot stock-in"></span> <span class="stock-text">In Stock</span>
            </div>

            <div class="product-card-actions">
              <form action="/cart/add" method="post" class="product-card-add-form" onclick="return false;">
                <!-- Dummy ID so AJAX handler intercepts but does not make a real Shopify API request in preview mode if not connected -->
                <input type="hidden" name="id" value="441830200000{{ i }}">
                <input type="hidden" name="quantity" value="1">
                <button type="submit" class="btn btn-primary product-card-btn">Add To Cart</button>
              </form>
            </div>
          </div>
        </div>
      {% endfor %}
      <!-- [FALLBACK MOCK CARDS END] -->

    {% endif %}
  </div>
</div>

{% stylesheet %}
  .products-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: var(--page-width);
    margin: 0 auto;
  }

  @media (min-width: 576px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 992px) {
    .products-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.75rem;
    }
  }

  .product-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-brand-coral);
    box-shadow: 0 12px 30px rgba(226, 108, 62, 0.15);
  }

  .product-card-image-wrapper {
    position: relative;
    width: 100%;
    padding-top: 100%; /* square ratio */
    background-color: #0b0b0c;
    overflow: hidden;
    border-bottom: 1px solid var(--color-brand-border);
  }

  .product-card-image-link {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-card-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1rem;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-card:hover .product-card-img {
    transform: scale(1.05);
  }

  .product-card-placeholder-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6d6b65;
  }

  .product-card-badges {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    z-index: 2;
  }

  .product-card-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex-grow: 1;
    background-color: rgba(28, 28, 30, 0.25);
  }

  .product-card-vendor {
    font-size: 0.75rem;
    color: var(--color-brand-coral);
    text-transform: uppercase;
    font-family: var(--font-heading);
    font-weight: 800;
    letter-spacing: 0.05em;
  }

  .product-card-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-brand-cream);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    height: 2.8rem;
  }

  .product-card-title a:hover {
    color: var(--color-brand-coral);
  }

  .product-card-price-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .product-price {
    font-size: 1.15rem;
    font-weight: 700;
    font-family: var(--font-heading);
    color: var(--color-brand-cream);
  }

  .product-price.price-sale {
    color: var(--color-brand-coral);
  }

  .product-compare-price {
    font-size: 0.85rem;
    text-decoration: line-through;
    color: #6d6b65;
  }

  /* stock dot indicators */
  .product-stock-status {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }

  .stock-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .stock-in {
    background-color: var(--color-brand-green);
    box-shadow: 0 0 6px var(--color-brand-green);
  }

  .stock-out {
    background-color: #6d6b65;
  }

  .stock-text {
    font-size: 0.75rem;
    color: #8c8982;
  }

  /* Actions button */
  .product-card-actions {
    margin-top: auto;
    width: 100%;
  }

  .product-card-btn {
    width: 100%;
    padding: 0.75rem;
    font-size: 0.85rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Products Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Title",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading Text",
      "default": "Grab the latest authentic hardware and accessories in our lineup."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Target Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 4,
      "max": 12,
      "step": 4,
      "label": "Product Limit",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Retro Product Grid",
      "category": "Collection"
    }
  ]
}
{% endschema %}
