<footer class="site-footer">
  <div class="footer-container">
    
    <!-- Column 1: Brand Info -->
    <div class="footer-column footer-brand-col">
      <a href="{{ routes.root_url }}" class="footer-logo-link">
        <img src="{{ 'retro-smoke-logo.png' | asset_url }}" 
             alt="{{ shop.name | default: 'Retro Smoke & Vape' }}" 
             class="footer-logo-img"
             width="180"
             height="45">
      </a>
      <p class="footer-brand-desc">
        {{ section.settings.about_text | default: "Premium vaporizers, glass hardware, and smoking accessories. Bringing high-quality gear and trusted local service online." }}
      </p>
      <p class="footer-brand-info">
        📍 {{ section.settings.store_city | default: "Houston" }}, {{ section.settings.store_state | default: "TX" }}
      </p>
    </div>

    <!-- Column 2: Categories -->
    <div class="footer-column">
      <h4 class="footer-col-title">Shop Category</h4>
      <ul class="footer-links-list">
        <li><a href="/collections/vaporizers">Vaporizers</a></li>
        <li><a href="/collections/glass">Glass Hardware</a></li>
        <li><a href="/collections/accessories">Accessories</a></li>
        <li><a href="/collections/cleaning">Cleaning Supplies</a></li>
        <li><a href="/collections/pod-vapes-disposables">Pod Vapes & Disposables</a></li>
      </ul>
    </div>

    <!-- Column 3: Featured Brands -->
    <div class="footer-column">
      <h4 class="footer-col-title">Popular Brands</h4>
      <ul class="footer-links-list">
        <li><a href="/collections/all?filter.p.vendor=Lookah">Lookah</a></li>
        <li><a href="/collections/all?filter.p.vendor=Yocan">Yocan</a></li>
        <li><a href="/collections/all?filter.p.vendor=PAX">PAX</a></li>
        <li><a href="/collections/all?filter.p.vendor=Dr.+Dabber">Dr. Dabber</a></li>
        <li><a href="/collections/all?filter.p.vendor=Storz+%26+Bickel">Storz & Bickel</a></li>
      </ul>
    </div>

    <!-- Column 4: Quick Links / Support -->
    <div class="footer-column">
      <h4 class="footer-col-title">Customer Care</h4>
      <ul class="footer-links-list">
        <li><a href="/pages/contact">Contact Us</a></li>
        <li><a href="/pages/shipping-policy">Shipping Policy</a></li>
        <li><a href="/pages/refund-policy">Refund Policy</a></li>
        <li><a href="/pages/privacy-policy">Privacy Policy</a></li>
        <li><a href="/pages/terms-of-service">Terms of Service</a></li>
      </ul>
    </div>

  </div>

  <!-- Disclaimer Area -->
  <div class="footer-disclaimer-wrapper">
    <div class="footer-disclaimer-card">
      <span class="warning-badge">21+ WARNING</span>
      <p class="disclaimer-text">
        {{ section.settings.disclaimer_text | default: "All products sold on this storefront are intended strictly for adult use (21+). Government-issued photo ID is required to verify age at delivery. We sell vapes, hardware, glass, and accessory products only. We DO NOT carry, distribute, or sell any THC, cannabis, or active herbal materials whatsoever. All sales are subject to local age restriction laws." }}
      </p>
    </div>
  </div>

  <!-- Bottom Bar (Copyright + Trust Logos) -->
  <div class="footer-bottom-bar">
    <div class="footer-bottom-container">
      <div class="footer-copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name | default: "Retro Smoke & Vape" }}. 
        {% if section.settings.store_city != blank %}{{ section.settings.store_city }}, {{ section.settings.store_state }}{% endif %}. 
        All rights reserved.
      </div>
      
      <!-- Payment Logos -->
      <div class="footer-payment-icons">
        {% if section.settings.show_payment_icons %}
          <!-- Render generic credit card logo slots (Visa, Mastercard, Amex, Discover) -->
          <svg class="payment-icon" viewBox="0 0 38 24" width="38" height="24" fill="none"><rect width="38" height="24" rx="3" fill="#00155C"/><path d="M12 16.5l2-9h3.5l-2 9H12zm11.25-9c-.75 0-1.4.4-1.75 1L20 16.5h3.5l.75-2h4l.35 2H32l-2.75-9h-6zm.75 5.5l1.5-4 1 4h-2.5zm-17-5.5h3.5L13 13.5l1.5-6H11l-3 4.5V7.5z" fill="#FFF"/></svg>
          <svg class="payment-icon" viewBox="0 0 38 24" width="38" height="24" fill="none"><rect width="38" height="24" rx="3" fill="#EB001B"/><circle cx="15" cy="12" r="7" fill="#F79E1B" fill-opacity="0.8"/><circle cx="23" cy="12" r="7" fill="#FF5F00" fill-opacity="0.8"/></svg>
          <svg class="payment-icon" viewBox="0 0 38 24" width="38" height="24" fill="none"><rect width="38" height="24" rx="3" fill="#0070CD"/><path d="M10 7.5L7.5 11l2.5 3.5h3L10.5 11 13 7.5h-3zm9 0L16.5 11l2.5 3.5h3l-2.5-3.5 2.5-3.5h-3zm8 0L24.5 11l2.5 3.5h3L27.5 11 30 7.5h-3z" fill="#FFF"/><path d="M4 16.5L6.5 7.5h3.5l-2.5 9H4z" fill="#F79E1B"/></svg>
          <svg class="payment-icon" viewBox="0 0 38 24" width="38" height="24" fill="none"><rect width="38" height="24" rx="3" fill="#FF8200"/><circle cx="19" cy="12" r="6" fill="#FFF"/><path d="M19 15.5l-2.5-3.5 2.5-3.5h3l-2.5 3.5 2.5 3.5h-3z" fill="#FF8200"/></svg>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .site-footer {
    background-color: var(--color-brand-charcoal);
    border-top: 1px solid var(--color-brand-border);
    margin-top: 5rem;
    padding-top: 4rem;
  }

  .footer-container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin) 3rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2.5rem;
  }

  .footer-brand-col {
    grid-column: span 1;
  }

  @media (min-width: 992px) {
    .footer-brand-col {
      grid-column: span 2;
      padding-right: 3rem;
    }
    .footer-container {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .footer-logo-link {
    display: inline-block;
    margin-bottom: 1.25rem;
  }
  .footer-logo-img {
    max-height: 48px;
    width: auto;
  }

  .footer-brand-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #9a9891;
    margin-bottom: 1rem;
  }

  .footer-brand-info {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-brand-cream);
  }

  .footer-col-title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-brand-cream);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.25rem;
    position: relative;
  }

  .footer-links-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links-list a {
    font-size: 0.85rem;
    color: #9a9891;
  }

  .footer-links-list a:hover {
    color: var(--color-brand-coral);
  }

  /* Disclaimer card styles */
  .footer-disclaimer-wrapper {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin) 3rem;
  }

  .footer-disclaimer-card {
    background-color: rgba(226, 108, 62, 0.03);
    border: 1px solid rgba(226, 108, 62, 0.12);
    border-radius: 6px;
    padding: 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer-disclaimer-card {
      flex-direction: row;
      text-align: left;
      gap: 2rem;
    }
  }

  .warning-badge {
    background-color: var(--color-brand-coral);
    color: var(--color-brand-charcoal);
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 0.75rem;
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .disclaimer-text {
    font-size: 0.8rem;
    line-height: 1.5;
    color: #8c8982;
  }

  /* Bottom Bar */
  .footer-bottom-bar {
    background-color: #0b0b0c;
    border-top: 1px solid var(--color-brand-border);
    padding: 1.5rem 0;
  }

  .footer-bottom-container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
  }

  @media (min-width: 768px) {
    .footer-bottom-container {
      flex-direction: row;
    }
  }

  .footer-copyright {
    font-size: 0.8rem;
    color: #6d6b65;
    text-align: center;
  }

  .footer-payment-icons {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .payment-icon {
    width: 38px;
    height: 24px;
    border-radius: 3px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "about_text",
      "label": "About Text"
    },
    {
      "type": "text",
      "id": "store_city",
      "label": "Store City",
      "default": "Houston"
    },
    {
      "type": "text",
      "id": "store_state",
      "label": "Store State",
      "default": "TX"
    },
    {
      "type": "textarea",
      "id": "disclaimer_text",
      "label": "Legal Disclaimer Text"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    }
  ]
}
{% endschema %}
