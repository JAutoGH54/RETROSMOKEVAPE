<div class="site-header-wrapper">
  <div class="site-header-container">
    
    <!-- Burger menu button (mobile) -->
    <button type="button" class="mobile-nav-toggle" id="mobile-nav-toggle" aria-label="Toggle Navigation">
      <span class="burger-bar"></span>
      <span class="burger-bar"></span>
      <span class="burger-bar"></span>
    </button>

    <!-- Header Logo -->
    <div class="header__logo-container">
      <a href="{{ routes.root_url }}" class="header__logo-link">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | image_url: width: 220 }}" 
               alt="{{ shop.name }}" 
               class="header__logo-img"
               width="180"
               height="45">
        {% else %}
          <img src="{{ 'retro-smoke-logo.png' | asset_img_url: '600x', format: 'webp' }}" 
               alt="{{ shop.name | default: 'Retro Smoke & Vape' }}" 
               class="header__logo-img"
               width="180"
               height="45">
        {% endif %}
      </a>
    </div>

    <!-- Desktop Navigation -->
    <nav class="header__desktop-nav" role="navigation">
      <ul class="desktop-nav-list">
        <li>
          <a href="/collections/new" class="desktop-nav-link">New</a>
        </li>
        <li>
          <a href="/collections/all" class="desktop-nav-link">Products</a>
        </li>
        <li class="nav-dropdown-item">
          <a href="#" class="desktop-nav-link dropdown-toggle" onclick="return false;">
            Brands <svg class="chevron-svg" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <div class="brands-dropdown-menu">
            <div class="brands-dropdown-grid">
              {% assign brands = "Lookah, Yocan, Cheech & Chong, Grateful Dead, Dr. Dabber, Pulsar, G Pen, Hemper, High Five, PAX, Grav, Grunge Off, Focus V, Storz & Bickel, Gear Premium, Ooze, Xvape" | split: ", " %}
              {% for brand in brands %}
                <a href="/collections/all?filter.p.vendor={{ brand | url_encode }}" class="brand-dropdown-link">{{ brand }}</a>
              {% endfor %}
            </div>
          </div>
        </li>
        <li>
          <a href="/collections/bargain-bin" class="desktop-nav-link color-coral font-bold">Bargain Bin</a>
        </li>
        <li>
          <a href="/pages/contact" class="desktop-nav-link">Contact</a>
        </li>
      </ul>
    </nav>

    <!-- Utility Icons (Search + Cart) -->
    <div class="header__utility-icons">
      <!-- Search Trigger -->
      <button class="header-icon-btn" id="search-trigger" aria-label="Open Search">
        <svg class="icon-svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>

      <!-- Cart Icon / Bubble -->
      <a href="{{ routes.cart_url }}" class="header-icon-btn cart-drawer-trigger" id="cart-icon-bubble" aria-label="Open Cart">
        <span class="cart-count-bubble" {% if cart.item_count == 0 %}style="display: none;"{% endif %}>
          {{ cart.item_count }}
        </span>
        <svg class="icon-svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
      </a>
    </div>

  </div>
</div>

<!-- Search Overlay Drawer -->
<div class="search-overlay" id="search-overlay">
  <div class="search-overlay-container">
    <form action="{{ routes.search_url }}" method="get" class="search-overlay-form">
      <input type="search" name="q" placeholder="Search the shop..." class="search-overlay-input" id="search-input-field">
      <input type="hidden" name="options[prefix]" value="last">
      <button type="submit" class="search-overlay-submit-btn">Search</button>
    </form>
    <button class="search-overlay-close-btn" id="search-overlay-close" aria-label="Close Search">✕</button>
  </div>
</div>

<!-- Mobile Navigation Drawer -->
<div class="mobile-nav-drawer" id="mobile-nav-drawer">
  <div class="mobile-nav-header">
    <a href="{{ routes.root_url }}" class="header__logo-link">
      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | image_url: width: 220 }}" 
             alt="{{ shop.name }}" 
             class="header__logo-img"
             width="180"
             height="45">
      {% else %}
        <img src="{{ 'retro-smoke-logo.png' | asset_img_url: '600x', format: 'webp' }}" 
             alt="{{ shop.name | default: 'Retro Smoke & Vape' }}" 
             class="header__logo-img"
             width="180"
             height="45">
      {% endif %}
    </a>
    <button class="mobile-nav-close" id="mobile-nav-close">✕</button>
  </div>
  <ul class="mobile-nav-list">
    <li><a href="/collections/new" class="mobile-nav-link">New</a></li>
    <li><a href="/collections/all" class="mobile-nav-link">Products</a></li>
    <li class="mobile-nav-dropdown">
      <button class="mobile-dropdown-toggle" id="mobile-brands-toggle">
        Brands <svg class="chevron-svg" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <ul class="mobile-dropdown-menu" id="mobile-brands-menu" style="display: none;">
        {% for brand in brands %}
          <li><a href="/collections/all?filter.p.vendor={{ brand | url_encode }}">{{ brand }}</a></li>
        {% endfor %}
      </ul>
    </li>
    <li><a href="/collections/bargain-bin" class="mobile-nav-link color-coral font-bold">Bargain Bin</a></li>
    <li><a href="/pages/contact" class="mobile-nav-link">Contact</a></li>
  </ul>
</div>

<div class="mobile-nav-backdrop" id="mobile-nav-backdrop"></div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Search toggle
    const searchTrigger = document.getElementById('search-trigger');
    const searchOverlay = document.getElementById('search-overlay');
    const searchClose = document.getElementById('search-overlay-close');
    const searchInputField = document.getElementById('search-input-field');

    if (searchTrigger && searchOverlay) {
      searchTrigger.addEventListener('click', function() {
        searchOverlay.classList.add('search-active');
        if (searchInputField) setTimeout(() => searchInputField.focus(), 150);
      });
    }

    if (searchClose) {
      searchClose.addEventListener('click', function() {
        searchOverlay.classList.remove('search-active');
      });
    }

    // Mobile nav drawer toggle
    const mobileToggle = document.getElementById('mobile-nav-toggle');
    const mobileClose = document.getElementById('mobile-nav-close');
    const mobileDrawer = document.getElementById('mobile-nav-drawer');
    const mobileBackdrop = document.getElementById('mobile-nav-backdrop');

    function openMobileMenu() {
      mobileDrawer.classList.add('active');
      mobileBackdrop.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeMobileMenu() {
      mobileDrawer.classList.remove('active');
      mobileBackdrop.classList.remove('active');
      document.body.removeAttribute('style');
    }

    if (mobileToggle) mobileToggle.addEventListener('click', openMobileMenu);
    if (mobileClose) mobileClose.addEventListener('click', closeMobileMenu);
    if (mobileBackdrop) mobileBackdrop.addEventListener('click', closeMobileMenu);

    // Mobile Brands Dropdown toggle
    const mobileBrandsToggle = document.getElementById('mobile-brands-toggle');
    const mobileBrandsMenu = document.getElementById('mobile-brands-menu');

    if (mobileBrandsToggle && mobileBrandsMenu) {
      mobileBrandsToggle.addEventListener('click', function() {
        const isCollapsed = mobileBrandsMenu.style.display === 'none';
        mobileBrandsMenu.style.display = isCollapsed ? 'block' : 'none';
        mobileBrandsToggle.classList.toggle('active');
      });
    }
  });
</script>

{% stylesheet %}
  .site-header-wrapper {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background-color: transparent;
    border-bottom: 1px solid transparent;
    transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .header--scrolled {
    background-color: rgba(15, 15, 16, 0.95);
    border-bottom: 1px solid var(--color-brand-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }

  .site-header-container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
    height: 5.5rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  /* Logo */
  .header__logo-container {
    grid-column: 2;
    justify-self: center;
    display: flex;
    align-items: center;
    transform: translateX(-24px);
  }
  .header__logo-link {
    display: flex;
    align-items: center;
  }
  .header__logo-text {
    font-family: var(--font-heading);
    font-size: 1.65rem;
    font-weight: 800;
    color: var(--color-brand-cream);
    text-transform: uppercase;
    letter-spacing: -0.03em;
  }
  .text-coral {
    color: var(--color-brand-coral);
  }
  .header__logo-img {
    max-height: 48px;
    width: auto;
  }

  /* Desktop Nav */
  .header__desktop-nav {
    display: none;
    height: 100%;
  }
  .desktop-nav-list {
    display: flex;
    align-items: center;
    list-style: none;
    gap: 2.25rem;
    height: 100%;
  }
  .desktop-nav-link {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-brand-cream);
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    height: 5.5rem;
  }
  .desktop-nav-link:hover,
  .desktop-nav-link.color-coral:hover {
    color: var(--color-brand-coral) !important;
  }
  .color-coral {
    color: var(--color-brand-coral) !important;
  }

  .chevron-svg {
    transition: transform 0.25s ease;
  }
  .desktop-nav-link:hover .chevron-svg {
    transform: rotate(180deg);
  }

  /* Brands Dropdown Menu */
  .nav-dropdown-item {
    position: relative;
  }
  .brands-dropdown-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background-color: var(--color-brand-charcoal-light);
    border: 1px solid var(--color-brand-border);
    border-radius: 8px;
    padding: 1.5rem;
    width: 480px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    z-index: 10;
  }
  .nav-dropdown-item:hover .brands-dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .brands-dropdown-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }
  .brand-dropdown-link {
    font-size: 0.85rem;
    color: #b3b0a8;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }
  .brand-dropdown-link:hover {
    color: var(--color-brand-coral);
    background-color: rgba(226, 108, 62, 0.05);
  }

  /* Icons */
  .header__utility-icons {
    grid-column: 3;
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .header-icon-btn {
    background: none;
    border: none;
    color: var(--color-brand-cream);
    cursor: pointer;
    position: relative;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }
  .header-icon-btn:hover {
    color: var(--color-brand-coral);
  }
  .icon-svg {
    stroke-width: 1.75;
  }

  .cart-count-bubble {
    position: absolute;
    top: -2px;
    right: -2px;
    background-color: var(--color-brand-coral);
    color: var(--color-brand-charcoal);
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 800;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Mobile menu button */
  .mobile-nav-toggle {
    grid-column: 1;
    justify-self: start;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 22px;
    height: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .burger-bar {
    width: 100%;
    height: 2px;
    background-color: var(--color-brand-cream);
    border-radius: 2px;
    transition: background-color 0.2s;
  }

  /* Search Drawer */
  .search-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 5.5rem;
    background-color: var(--color-brand-charcoal);
    border-bottom: 1px solid var(--color-brand-border);
    z-index: 105;
    opacity: 0;
    transform: translateY(-100%);
    transition: opacity 0.3s ease, transform 0.3s ease;
    visibility: hidden;
  }
  .search-overlay.search-active {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
  }
  .search-overlay-container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .search-overlay-form {
    flex: 1;
    display: flex;
    gap: 1rem;
    max-width: 720px;
    margin: 0 auto;
  }
  .search-overlay-input {
    background-color: var(--color-brand-charcoal-light);
    border-color: rgba(230, 209, 172, 0.15);
  }
  .search-overlay-submit-btn {
    background-color: var(--color-brand-coral);
    color: var(--color-brand-charcoal);
    font-family: var(--font-heading);
    font-weight: 700;
    padding: 0 1.5rem;
    border-radius: 4px;
    border: none;
    cursor: pointer;
  }
  .search-overlay-close-btn {
    background: none;
    border: none;
    color: var(--color-brand-cream);
    font-size: 1.5rem;
    cursor: pointer;
  }

  /* Mobile Nav Drawer */
  .mobile-nav-drawer {
    position: fixed;
    top: 0;
    left: 0;
    width: 290px;
    height: 100%;
    background-color: var(--color-brand-charcoal);
    border-right: 1px solid var(--color-brand-border);
    z-index: 200;
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    padding: 2rem 1.5rem;
  }
  .mobile-nav-drawer.active {
    transform: translateX(0);
  }
  .mobile-nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }
  .mobile-nav-close {
    background: none;
    border: none;
    color: var(--color-brand-cream);
    font-size: 1.5rem;
    cursor: pointer;
  }
  .mobile-nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .mobile-nav-link, .mobile-dropdown-toggle {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-brand-cream);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: none;
    border: none;
    width: 100%;
    text-align: left;
    cursor: pointer;
    padding: 0;
  }
  .mobile-dropdown-toggle .chevron-svg {
    transform: rotate(0deg);
  }
  .mobile-dropdown-toggle.active .chevron-svg {
    transform: rotate(180deg);
  }
  .mobile-dropdown-menu {
    list-style: none;
    padding-left: 1rem;
    margin-top: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-height: 250px;
    overflow-y: auto;
    border-left: 1px solid var(--color-brand-border);
  }
  .mobile-dropdown-menu a {
    font-size: 0.95rem;
    color: #b3b0a8;
    display: block;
    padding: 0.25rem 0;
  }

  .mobile-nav-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(0,0,0,0.6);
    z-index: 199;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s;
  }
  .mobile-nav-backdrop.active {
    opacity: 1;
    visibility: visible;
  }

  /* Responsive Display Rules */
  @media (min-width: 992px) {
    .mobile-nav-toggle {
      display: none;
    }
    .header__desktop-nav {
      display: block;
      grid-column: 1;
      justify-self: start;
      height: 100%;
    }
    .site-header-container {
      height: 6rem;
    }
    .desktop-nav-link {
      height: 6rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Custom Logo Image"
    }
  ]
}
{% endschema %}
