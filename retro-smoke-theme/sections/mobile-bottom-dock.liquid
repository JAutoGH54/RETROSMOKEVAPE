{%- assign best_sellers_url = routes.all_products_collection_url | append: '?sort_by=best-selling' -%}
{%- if section.settings.best_sellers_collection != blank -%}
  {%- assign best_sellers_url = collections[section.settings.best_sellers_collection].url -%}
{%- endif -%}

<!-- Sections: Mobile Bottom Dock & Sticky ATC -->

<div class="mobile-navigation-elements" id="mobile-nav-elements">
  
  <!-- [NAV DOCK] -->
  <nav class="mobile-bottom-dock glass-dock" id="mobile-bottom-dock" aria-label="Mobile Navigation">
    <div class="dock-container">
      <a href="{{ routes.root_url }}" class="dock-item {% if template.name == 'index' %}active{% endif %}" aria-label="Go to Home">
        <svg class="dock-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
        <span class="dock-label">Home</span>
      </a>

      <button type="button" class="dock-item" id="dock-search-trigger" aria-label="Open Search">
        <svg class="dock-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span class="dock-label">Search</span>
      </button>

      <!-- PREMIUM INTERACTIVE FEATURE TRIGGER (BEST SELLERS) -->
      <a href="{{ best_sellers_url }}" class="dock-item special-best-trigger {% if best_sellers_url == request.path %}active{% endif %}" aria-label="Best Sellers">
        <div class="best-icon-wrapper">
          <!-- Retro Star SVG -->
          <svg class="dock-icon star-icon" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
          </svg>
          <span class="sparkle-dot top-left"></span>
          <span class="sparkle-dot bottom-right"></span>
        </div>
        <span class="dock-label label-glow">Best<br>Sellers</span>
      </a>

      <a href="{{ routes.collections_url }}/bargain-bin" class="dock-item {% if template.suffix == 'bargain-bin' or collection.handle == 'bargain-bin' %}active{% endif %}" aria-label="Bargain Bin">
        <svg class="dock-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="1" x2="12" y2="23"></line>
          <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
        </svg>
        <span class="dock-label">Deals</span>
      </a>

      <button type="button" class="dock-item cart-drawer-trigger" aria-label="Open Cart">
        <div class="cart-icon-wrapper">
          <svg class="dock-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
          <span class="cart-count-bubble dock-cart-bubble" {% if cart.item_count == 0 %}style="display: none;"{% endif %}>
            {{ cart.item_count }}
          </span>
        </div>
        <span class="dock-label">Cart</span>
      </button>
    </div>
  </nav>

  <!-- [STICKY ADD TO CART BAR] (Product pages only) -->
  {% if template.name == 'product' %}
    <div class="mobile-sticky-atc glass-dock" id="mobile-sticky-atc">
      <div class="sticky-atc-container">
        
        <div class="sticky-atc-product-info">
          {% if product.featured_image != blank %}
            <img src="{{ product.featured_image | image_url: width: 100, height: 100, crop: 'center' }}" 
                 alt="{{ product.title }}" 
                 class="sticky-atc-img"
                 width="44"
                 height="44"
                 loading="lazy">
          {% endif %}
          <div class="sticky-atc-text">
            <span class="sticky-atc-title">{{ product.title }}</span>
            <span class="sticky-atc-price" id="sticky-price-display">{{ product.selected_or_first_available_variant.price | money }}</span>
          </div>
        </div>

        <div class="sticky-atc-actions">
          {% if product.variants.size > 1 %}
            <button type="button" class="btn btn-secondary sticky-options-btn" id="sticky-options-trigger">
              <span class="selected-variant-label" id="sticky-variant-title">
                {{ product.selected_or_first_available_variant.title }}
              </span>
              <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 5L5 1L9 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button type="button" class="btn btn-primary sticky-add-btn" id="sticky-add-cart-submit">Add</button>
          {% else %}
            <input type="hidden" id="sticky-single-variant-id" value="{{ product.variants.first.id }}">
            <button type="button" class="btn btn-primary sticky-add-btn full-width-action" id="sticky-add-cart-submit-single">Add to Cart</button>
          {% endif %}
        </div>

      </div>
    </div>

    <!-- [IOS-STYLE SLIDE-UP VARIANT SHEET] -->
    {% if product.variants.size > 1 %}
      <div class="variant-sheet-backdrop" id="variant-sheet-backdrop"></div>
      <div class="variant-sheet" id="variant-sheet" role="dialog" aria-modal="true" aria-hidden="true">
        <div class="variant-sheet-header">
          <div class="variant-sheet-drag-handle"></div>
          <h3>Select Options</h3>
          <button class="variant-sheet-close-btn" id="variant-sheet-close" aria-label="Close Options">✕</button>
        </div>
        
        <div class="variant-sheet-content">
          <div class="sheet-product-summary">
            {% if product.featured_image != blank %}
              <img src="{{ product.featured_image | image_url: width: 120 }}" 
                   alt="{{ product.title }}" 
                   class="sheet-summary-img"
                   id="sheet-summary-img"
                   width="60"
                   height="60"
                   loading="lazy">
            {% endif %}
            <div class="sheet-summary-details">
              <h4>{{ product.title }}</h4>
              <span class="sheet-summary-price" id="sheet-price-display">{{ product.selected_or_first_available_variant.price | money }}</span>
            </div>
          </div>

          <div class="variant-options-list">
            {% for variant in product.variants %}
              <div class="variant-option-card {% if variant == product.selected_or_first_available_variant %}selected{% endif %} {% unless variant.available %}sold-out{% endunless %}"
                   data-variant-id="{{ variant.id }}"
                   data-variant-title="{{ variant.title }}"
                   data-variant-price="{{ variant.price | money }}"
                   data-variant-image="{% if variant.featured_image != blank %}{{ variant.featured_image | image_url: width: 120 }}{% else %}{{ product.featured_image | image_url: width: 120 }}{% endif %}"
                   data-available="{{ variant.available }}">
                
                <div class="variant-card-radio">
                  <div class="radio-inner"></div>
                </div>

                <div class="variant-card-info">
                  <span class="variant-card-title">{{ variant.title }}</span>
                  {% unless variant.available %}
                    <span class="variant-card-status">Sold Out</span>
                  {% endunless %}
                </div>

                <span class="variant-card-price">{{ variant.price | money }}</span>
              </div>
            {% endfor %}
          </div>

          <div class="variant-sheet-action">
            <button type="button" class="btn btn-primary btn-confirm-variant" id="sheet-confirm-add-btn">
              Add to Cart
            </button>
          </div>
        </div>
      </div>
    {% endif %}
  {% endif %}

</div>

<!-- Self-Contained Premium Styles -->
<style>
  /* Base wrapper and utility classes */
  .mobile-navigation-elements {
    display: none; /* Hidden by default (Desktop) */
    z-index: 150;
  }

  @media (max-width: 991px) {
    .mobile-navigation-elements {
      display: block;
    }
  }

  /* Glassmorphism Navigation Dock */
  .glass-dock {
    position: fixed;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%) translateY(0);
    width: calc(100% - 2.5rem);
    max-width: 440px;
    height: 4.25rem;
    background-color: rgba(15, 15, 16, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1.5px solid var(--color-brand-border);
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4), 
                inset 0 1px 0 rgba(230, 209, 172, 0.1);
    z-index: 160;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), 
                opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-bottom-dock.dock--hidden {
    transform: translateX(-50%) translateY(130%);
    opacity: 0;
    pointer-events: none;
  }

  .dock-container {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    height: 100%;
    align-items: center;
    padding: 0 0.5rem;
  }

  .dock-item {
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #8c8982;
    text-decoration: none;
    cursor: pointer;
    gap: 0.25rem;
    position: relative;
    transition: color 0.2s, transform 0.1s;
    -webkit-tap-highlight-color: transparent;
  }

  .dock-item:active {
    transform: scale(0.92);
  }

  .dock-item.active {
    color: var(--color-brand-coral);
  }

  .dock-icon {
    stroke-width: 1.75;
    transition: transform 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .dock-item:active .dock-icon {
    transform: scale(1.15);
  }

  .dock-label {
    font-size: 0.62rem;
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    opacity: 0.8;
    line-height: 1.1;
    text-align: center;
  }

  /* Special Best Sellers Trigger Button Styling */
  .special-best-trigger {
    color: var(--color-brand-cream);
  }

  .best-icon-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .star-icon {
    color: var(--color-brand-green);
    filter: drop-shadow(0 0 6px rgba(36, 168, 104, 0.5));
    animation: pulseIcon 3s infinite ease-in-out;
  }

  .label-glow {
    color: var(--color-brand-cream);
    text-shadow: 0 0 8px rgba(230, 209, 172, 0.3);
  }

  .special-best-trigger .label-glow {
    color: var(--color-brand-coral);
    text-shadow: 0 0 8px rgba(226, 108, 62, 0.5);
  }

  /* Micro Sparkle animations for Quiz icon */
  .sparkle-dot {
    position: absolute;
    width: 4px;
    height: 4px;
    background-color: var(--color-brand-coral);
    border-radius: 50%;
    opacity: 0;
    pointer-events: none;
  }
  .sparkle-dot.top-left {
    top: -4px;
    left: -4px;
    animation: sparkleAnim 4s infinite 1s;
  }
  .sparkle-dot.bottom-right {
    bottom: -4px;
    right: -4px;
    background-color: var(--color-brand-cream);
    animation: sparkleAnim 4s infinite 3s;
  }

  /* Cart Notification bubble inside dock */
  .cart-icon-wrapper {
    position: relative;
  }

  .dock-cart-bubble {
    position: absolute;
    top: -5px;
    right: -7px;
    background-color: var(--color-brand-coral);
    color: var(--color-brand-charcoal);
    font-family: var(--font-heading);
    font-size: 0.6rem;
    font-weight: 800;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 10px rgba(226, 108, 62, 0.4);
    animation: popBubble 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  /* ----------------------------------
     Sticky Add to Cart Bar
     ---------------------------------- */
  .mobile-sticky-atc {
    position: fixed;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%) translateY(140%);
    width: calc(100% - 2.5rem);
    max-width: 440px;
    height: 4.5rem;
    background-color: rgba(15, 15, 16, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1.5px solid var(--color-brand-border);
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5), 
                inset 0 1px 0 rgba(230, 209, 172, 0.1);
    z-index: 159;
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), 
                opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-sticky-atc.atc--visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }

  .sticky-atc-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 0.85rem;
    gap: 0.75rem;
  }

  .sticky-atc-product-info {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex: 1;
    min-width: 0; /* truncate setup */
  }

  .sticky-atc-img {
    width: 42px;
    height: 42px;
    object-fit: contain;
    border-radius: 8px;
    background-color: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(230, 209, 172, 0.05);
    padding: 2px;
    flex-shrink: 0;
  }

  .sticky-atc-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .sticky-atc-title {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-brand-cream);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sticky-atc-price {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-brand-coral);
    margin-top: 0.1rem;
  }

  .sticky-atc-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .sticky-options-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.55rem 0.65rem;
    font-size: 0.7rem;
    border-radius: 12px;
    border-color: rgba(230, 209, 172, 0.15);
    background-color: rgba(28, 28, 30, 0.6);
    color: var(--color-brand-cream);
    max-width: 110px;
  }

  .selected-variant-label {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-family: var(--font-heading);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .sticky-add-btn {
    padding: 0.65rem 1rem;
    font-size: 0.75rem;
    border-radius: 12px;
    min-height: auto;
    font-family: var(--font-heading);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .sticky-add-btn.full-width-action {
    padding: 0.7rem 1.5rem;
  }

  /* ----------------------------------
     iOS-Style Slide-up Variant Sheet
     ---------------------------------- */
  .variant-sheet-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 210;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s ease, visibility 0.35s;
  }

  .variant-sheet-backdrop.active {
    opacity: 1;
    visibility: visible;
  }

  .variant-sheet {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    max-height: 80vh;
    background-color: var(--color-brand-charcoal);
    border-top: 2px solid var(--color-brand-border);
    border-top-left-radius: 24px;
    border-top-right-radius: 24px;
    z-index: 220;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    padding-bottom: env(safe-area-inset-bottom, 1rem);
  }

  .variant-sheet.active {
    transform: translateY(0);
  }

  .variant-sheet-header {
    position: relative;
    padding: 1.25rem 1.25rem 0.75rem 1.25rem;
    text-align: center;
    border-bottom: 1px solid rgba(230, 209, 172, 0.05);
    flex-shrink: 0;
  }

  .variant-sheet-drag-handle {
    width: 36px;
    height: 4px;
    background-color: rgba(230, 209, 172, 0.2);
    border-radius: 2px;
    margin: 0 auto 0.75rem auto;
  }

  .variant-sheet-header h3 {
    margin: 0;
    font-size: 1.1rem;
    font-family: var(--font-heading);
    text-transform: uppercase;
    color: var(--color-brand-cream);
    letter-spacing: 0.05em;
  }

  .variant-sheet-close-btn {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    background: none;
    border: none;
    color: var(--color-brand-cream);
    font-size: 1.15rem;
    cursor: pointer;
    padding: 0.25rem;
    opacity: 0.6;
  }

  .variant-sheet-content {
    overflow-y: auto;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    flex-grow: 1;
    -webkit-overflow-scrolling: touch;
  }

  /* Product quick display inside sheet */
  .sheet-product-summary {
    display: flex;
    align-items: center;
    gap: 1rem;
    background-color: rgba(28, 28, 30, 0.4);
    border: 1px solid var(--color-brand-border);
    border-radius: 12px;
    padding: 0.75rem;
  }

  .sheet-summary-img {
    width: 60px;
    height: 60px;
    object-fit: contain;
    border-radius: 6px;
    background-color: #050506;
    padding: 4px;
  }

  .sheet-summary-details {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sheet-summary-details h4 {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-brand-cream);
  }

  .sheet-summary-price {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-brand-coral);
  }

  /* Options list scrollable */
  .variant-options-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-height: 280px;
    overflow-y: auto;
  }

  .variant-option-card {
    display: flex;
    align-items: center;
    padding: 0.85rem 1rem;
    border: 1px solid rgba(230, 209, 172, 0.1);
    border-radius: 12px;
    background-color: rgba(28, 28, 30, 0.2);
    cursor: pointer;
    transition: all 0.2s ease;
    gap: 0.75rem;
  }

  .variant-option-card:hover {
    border-color: rgba(230, 209, 172, 0.25);
  }

  .variant-option-card.selected {
    background-color: rgba(36, 168, 104, 0.05);
    border-color: var(--color-brand-green);
    box-shadow: 0 0 12px rgba(36, 168, 104, 0.15);
  }

  .variant-option-card.sold-out {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .variant-card-radio {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 2px solid rgba(230, 209, 172, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .variant-option-card.selected .variant-card-radio {
    border-color: var(--color-brand-green);
  }

  .radio-inner {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: transparent;
    transition: background-color 0.2s;
  }

  .variant-option-card.selected .radio-inner {
    background-color: var(--color-brand-green);
  }

  .variant-card-info {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .variant-card-title {
    font-size: 0.85rem;
    font-family: var(--font-heading);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-brand-cream);
  }

  .variant-card-status {
    font-size: 0.65rem;
    color: var(--color-brand-coral);
    font-weight: 700;
    text-transform: uppercase;
  }

  .variant-card-price {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-brand-cream);
  }

  .variant-option-card.selected .variant-card-price {
    color: var(--color-brand-green);
  }

  /* Sheet confirm CTA button container */
  .variant-sheet-action {
    margin-top: auto;
    padding-top: 0.5rem;
    flex-shrink: 0;
  }

  .btn-confirm-variant {
    width: 100%;
    padding: 0.9rem;
    font-size: 0.9rem;
    border-radius: 12px;
    font-family: var(--font-heading);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Keyframe Animations */
  @keyframes pulseIcon {
    0%, 100% {
      transform: scale(1);
      filter: drop-shadow(0 0 6px rgba(36, 168, 104, 0.4));
    }
    50% {
      transform: scale(1.08);
      filter: drop-shadow(0 0 12px rgba(36, 168, 104, 0.7));
    }
  }

  @keyframes sparkleAnim {
    0%, 100% {
      transform: scale(0) rotate(0deg);
      opacity: 0;
    }
    5% {
      opacity: 0.8;
    }
    10% {
      transform: scale(1) rotate(45deg);
      opacity: 0.8;
    }
    15%, 95% {
      transform: scale(0) rotate(90deg);
      opacity: 0;
    }
  }

  @keyframes popBubble {
    0% { transform: scale(0); }
    70% { transform: scale(1.2); }
    100% { transform: scale(1); }
  }
</style>

<!-- Script for Bottom Dock and Sticky ATC Synchronicity -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    
    // ----------------------------------
    // 1. Search Hook
    // ----------------------------------
    const dockSearchBtn = document.getElementById('dock-search-trigger');
    const headerSearchBtn = document.getElementById('search-trigger');
    if (dockSearchBtn) {
      dockSearchBtn.addEventListener('click', function(e) {
        e.preventDefault();
        if (headerSearchBtn) {
          headerSearchBtn.click();
        } else {
          // Fallback if header trigger is missing
          const overlay = document.getElementById('search-overlay');
          if (overlay) overlay.classList.add('search-active');
        }
      });
    }

    // ----------------------------------
    // 2. Product Page Viewport Tracking
    // ----------------------------------
    const dock = document.getElementById('mobile-bottom-dock');
    const stickyAtc = document.getElementById('mobile-sticky-atc');
    
    if (stickyAtc && dock) {
      // Find the main add to cart button inside the product section
      const mainForm = document.querySelector('form[action*="/cart/add"]');
      const mainSubmitBtn = mainForm ? mainForm.querySelector('[type="submit"]') : null;

      if (mainSubmitBtn) {
        const observerOptions = {
          root: null,
          rootMargin: '0px 0px -60px 0px', // Trigger slightly before it fully leaves
          threshold: 0
        };

        const atcObserver = new IntersectionObserver(function(entries) {
          entries.forEach(entry => {
            if (!entry.isIntersecting) {
              // Scrolled past main ATC -> show sticky ATC, hide navigation dock
              dock.classList.add('dock--hidden');
              stickyAtc.classList.add('atc--visible');
            } else {
              // Main ATC visible -> hide sticky ATC, show navigation dock
              dock.classList.remove('dock--hidden');
              stickyAtc.classList.remove('atc--visible');
            }
          });
        }, observerOptions);

        atcObserver.observe(mainSubmitBtn);
      } else {
        // Fallback: If product page has no submit button, keep dock visible
        dock.classList.remove('dock--hidden');
        stickyAtc.classList.remove('atc--visible');
      }
    }

    // ----------------------------------
    // 3. Variant Sheet Interactions & AJAX Cart Sync
    // ----------------------------------
    const sheetTrigger = document.getElementById('sticky-options-trigger');
    const sheet = document.getElementById('variant-sheet');
    const backdrop = document.getElementById('variant-sheet-backdrop');
    const sheetClose = document.getElementById('variant-sheet-close');
    
    let activeVariantId = null;

    if (sheetTrigger && sheet && backdrop) {
      function openSheet() {
        sheet.classList.add('active');
        backdrop.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      function closeSheet() {
        sheet.classList.remove('active');
        backdrop.classList.remove('active');
        document.body.removeAttribute('style');
      }

      sheetTrigger.addEventListener('click', openSheet);
      if (sheetClose) sheetClose.addEventListener('click', closeSheet);
      backdrop.addEventListener('click', closeSheet);

      // Listen to variant card selections
      const optionCards = document.querySelectorAll('.variant-option-card');
      const stickyVariantTitle = document.getElementById('sticky-variant-title');
      const stickyPriceDisplay = document.getElementById('sticky-price-display');
      const sheetPriceDisplay = document.getElementById('sheet-price-display');
      const sheetSummaryImg = document.getElementById('sheet-summary-img');
      const mainVariantSelect = document.querySelector('form[action*="/cart/add"] select[name="id"]');

      optionCards.forEach(card => {
        card.addEventListener('click', function() {
          if (this.classList.contains('sold-out')) return;

          // Remove selected from others
          optionCards.forEach(c => c.classList.remove('selected'));
          this.classList.add('selected');

          // Retrieve selected details
          const id = this.getAttribute('data-variant-id');
          const title = this.getAttribute('data-variant-title');
          const price = this.getAttribute('data-variant-price');
          const imgSrc = this.getAttribute('data-variant-image');

          activeVariantId = id;

          // Update UI components
          if (stickyVariantTitle) stickyVariantTitle.textContent = title;
          if (stickyPriceDisplay) stickyPriceDisplay.textContent = price;
          if (sheetPriceDisplay) sheetPriceDisplay.textContent = price;
          if (sheetSummaryImg && imgSrc) sheetSummaryImg.src = imgSrc;

          // Synchronize with the main product form's variant select dropdown!
          if (mainVariantSelect) {
            mainVariantSelect.value = id;
            mainVariantSelect.dispatchEvent(new Event('change', { bubbles: true }));
          }
        });
      });

      // Quick Add from Variant Sheet (Add to Cart)
      const sheetConfirmBtn = document.getElementById('sheet-confirm-add-btn');
      if (sheetConfirmBtn) {
        sheetConfirmBtn.addEventListener('click', function(e) {
          e.preventDefault();
          
          // Get the selected variant ID
          const selectedCard = document.querySelector('.variant-option-card.selected');
          if (!selectedCard) {
            alert('Please select an option first.');
            return;
          }
          const variantId = selectedCard.getAttribute('data-variant-id');
          
          // Execute AJAX add to cart
          addVariantToCartAjax(variantId, sheetConfirmBtn, 'Add to Cart', function() {
            closeSheet();
          });
        });
      }

      // Add to Cart from the Sticky ATC bar itself
      const stickyAddBtn = document.getElementById('sticky-add-cart-submit');
      if (stickyAddBtn) {
        stickyAddBtn.addEventListener('click', function(e) {
          e.preventDefault();
          
          const selectedCard = document.querySelector('.variant-option-card.selected');
          const variantId = selectedCard ? selectedCard.getAttribute('data-variant-id') : null;
          
          if (!variantId) {
            // If no option has been set, open variant sheet to make user choose
            openSheet();
            return;
          }

          addVariantToCartAjax(variantId, stickyAddBtn, 'Add');
        });
      }
    }

    // Single variant Add to Cart
    const stickyAddSingleBtn = document.getElementById('sticky-add-cart-submit-single');
    const singleVariantIdInput = document.getElementById('sticky-single-variant-id');
    if (stickyAddSingleBtn && singleVariantIdInput) {
      stickyAddSingleBtn.addEventListener('click', function(e) {
        e.preventDefault();
        const variantId = singleVariantIdInput.value;
        addVariantToCartAjax(variantId, stickyAddSingleBtn, 'Add to Cart');
      });
    }

    // Helper function for AJAX additions
    function addVariantToCartAjax(variantId, btnElement, originalText, callback) {
      btnElement.disabled = true;
      btnElement.textContent = 'Adding...';

      const formData = {
        'items': [{
          'id': parseInt(variantId),
          'quantity': 1
        }]
      };

      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(formData)
      })
      .then(response => {
        if (!response.ok) {
          throw new Error('Network error adding to cart');
        }
        return response.json();
      })
      .then(data => {
        btnElement.textContent = 'Added!';
        
        // Trigger Shopify theme cart bubble count update
        if (typeof updateCartCountBubbles === 'function') {
          updateCartCountBubbles();
        } else {
          // Fallback count update
          fetch('/cart.js')
            .then(res => res.json())
            .then(cart => {
              const bubbles = document.querySelectorAll('.cart-count-bubble');
              bubbles.forEach(bubble => {
                bubble.textContent = cart.item_count;
                bubble.style.display = cart.item_count > 0 ? 'flex' : 'none';
              });
            });
        }

        // Open the cart drawer
        const drawer = document.getElementById('cart-drawer');
        if (drawer) {
          drawer.setAttribute('aria-hidden', 'false');
          document.documentElement.setAttribute('data-drawer-open', 'true');
          
          if (typeof fetchCartDrawerHTML === 'function') {
            fetchCartDrawerHTML();
          }
        }

        setTimeout(() => {
          btnElement.textContent = originalText;
          btnElement.disabled = false;
          if (callback) callback();
        }, 1000);
      })
      .catch(error => {
        console.error('Error adding variant:', error);
        btnElement.textContent = 'Error';
        setTimeout(() => {
          btnElement.textContent = originalText;
          btnElement.disabled = false;
        }, 1500);
      });
    }

  });
</script>

