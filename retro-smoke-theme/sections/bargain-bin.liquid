<div class="bargain-bin-section section-spacing">
  <div class="bargain-bin-banner glass-panel reveal-on-scroll">
    <div class="bargain-bin-container">
      
      <div class="bargain-header-block reveal-on-scroll delay-100">
        <span class="bargain-badge">LIMITED QUANTITIES</span>
        <h2>{{ section.settings.heading | default: "Bargain Bin Deals" }}</h2>
        <p>{{ section.settings.subheading | default: "Grab top-tier hardware, glass, and accessory close-outs before they're gone forever." }}</p>
      </div>

      <div class="bargain-grid">
        {% assign selected_collection = collections[section.settings.collection] %}
        
        {% if selected_collection != blank and selected_collection.products_count > 0 %}
          
          <!-- [DYNAMIC DUAL-PRICED LOOP] -->
          {% for product in selected_collection.products limit: 3 %}
            {% assign loop_index_mod = forloop.index0 | modulo: 3 %}
            {% assign delay_class = "" %}
            {% if loop_index_mod == 1 %}{% assign delay_class = "delay-100" %}
            {% elsif loop_index_mod == 2 %}{% assign delay_class = "delay-200" %}{% endif %}

            <div class="bargain-card glass-panel reveal-on-scroll {{ delay_class }}">
              <div class="bargain-image-wrapper">
                <a href="{{ product.url }}">
                  {% if product.featured_image != blank %}
                    <img src="{{ product.featured_image | image_url: width: 500, height: 500, crop: 'center' }}" 
                         alt="{{ product.title | escape }}" 
                         class="bargain-card-img"
                         width="250"
                         height="250"
                         loading="lazy">
                  {% else %}
                    <div class="product-card-placeholder-img">📦</div>
                  {% endif %}
                </a>
                <span class="badge badge-sale bargain-card-badge">Save {% if product.compare_at_price > product.price %}{{ product.compare_at_price | minus: product.price | money }}{% else %}Big{% endif %}</span>
              </div>
              
              <div class="bargain-card-content">
                <span class="bargain-card-vendor">{{ product.vendor }}</span>
                <h3 class="bargain-card-title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
                
                <div class="bargain-price-row">
                  <span class="bargain-price-sale">{{ product.price | money }}</span>
                  {% if product.compare_at_price > product.price %}
                    <span class="bargain-price-compare">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                </div>

                <div class="bargain-card-action">
                  <a href="{{ product.url }}" class="btn btn-secondary bargain-btn-quick">View Deal</a>
                </div>
              </div>
            </div>
          {% endfor %}

        {% else %}

          <!-- [FALLBACK MOCK BARGAIN CARDS] -->
          {% assign mock_names = "Ooze Slim Twist Battery, Grav Labs Helix Pipe, Grunge Off Glass Cleaner" | split: ", " %}
          {% assign mock_vendors = "Ooze, Grav, Grunge Off" | split: ", " %}
          {% assign mock_prices = "$12.99, $89.99, $14.99" | split: ", " %}
          {% assign mock_compare_prices = "$19.99, $120.00, $21.99" | split: ", " %}
          {% assign mock_emojis = "🔋, 🔮, 🧼" | split: ", " %}
          {% assign mock_delays = "delay-100, delay-200, delay-300" | split: ", " %}

          {% for i in (0..2) %}
            <div class="bargain-card glass-panel reveal-on-scroll {{ mock_delays[i] }}">
              <div class="bargain-image-wrapper">
                <div class="bargain-card-placeholder-img" style="background-image: linear-gradient(135deg, #1c1c1e 0%, #151516 100%);">
                  <span style="font-size: 3rem;">{{ mock_emojis[i] }}</span>
                </div>
                <span class="badge badge-sale bargain-card-badge">Save Deal</span>
              </div>

              <div class="bargain-card-content">
                <span class="bargain-card-vendor">{{ mock_vendors[i] }}</span>
                <h3 class="bargain-card-title"><a href="#" onclick="return false;">{{ mock_names[i] }}</a></h3>
                
                <div class="bargain-price-row">
                  <span class="bargain-price-sale">{{ mock_prices[i] }}</span>
                  <span class="bargain-price-compare">{{ mock_compare_prices[i] }}</span>
                </div>

                <div class="bargain-card-action">
                  <a href="#" onclick="return false;" class="btn btn-secondary bargain-btn-quick">View Deal</a>
                </div>
              </div>
            </div>
          {% endfor %}

        {% endif %}
      </div>

      <div class="bargain-bin-cta reveal-on-scroll delay-200">
        <a href="{{ section.settings.link | default: '/collections/bargain-bin' }}" class="btn btn-primary bargain-view-all-btn">
          {{ section.settings.button_text | default: "Shop the Bargain Bin" }}
        </a>
      </div>

    </div>
  </div>
</div>

{% stylesheet %}
  .bargain-bin-banner {
    background-color: rgba(28, 28, 30, 0.25);
    background-image: radial-gradient(circle at top right, rgba(226, 108, 62, 0.04) 0%, transparent 50%);
    border: 1px solid var(--color-brand-border);
    border-radius: 12px;
    padding: 3rem 1.5rem;
    max-width: var(--page-width);
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .bargain-bin-banner {
      padding: 4rem 3rem;
    }
  }

  .bargain-header-block {
    text-align: center;
    margin-bottom: 3rem;
  }

  .bargain-badge {
    color: var(--color-brand-coral);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .bargain-header-block h2 {
    font-size: 2.25rem;
    text-transform: uppercase;
    color: var(--color-brand-cream);
    margin-bottom: 0.75rem;
  }

  .bargain-header-block p {
    max-width: 600px;
    margin: 0 auto;
    color: #9a9891;
  }

  .bargain-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .bargain-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.75rem;
    }
  }

  .bargain-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s ease;
  }

  .bargain-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-brand-coral);
    box-shadow: 0 10px 25px rgba(226, 108, 62, 0.15);
  }

  .bargain-image-wrapper {
    position: relative;
    width: 100%;
    padding-top: 100%;
    overflow: hidden;
    background-color: #050506;
    border-bottom: 1px solid rgba(230, 209, 172, 0.05);
  }

  .bargain-card-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1.5rem;
    transition: transform 0.4s ease;
  }

  .bargain-card:hover .bargain-card-img {
    transform: scale(1.05);
  }

  .bargain-card-placeholder-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bargain-card-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 2;
  }

  .bargain-card-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex-grow: 1;
    background-color: rgba(28, 28, 30, 0.25);
  }

  .bargain-card-vendor {
    font-size: 0.7rem;
    font-family: var(--font-heading);
    font-weight: 800;
    text-transform: uppercase;
    color: #8c8982;
    letter-spacing: 0.05em;
  }

  .bargain-card-title {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-brand-cream);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    height: 2.8rem;
  }

  .bargain-card-title a:hover {
    color: var(--color-brand-coral);
  }

  .bargain-price-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .bargain-price-sale {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-brand-coral);
  }

  .bargain-price-compare {
    font-size: 0.8rem;
    text-decoration: line-through;
    color: #6d6b65;
  }

  .bargain-card-action {
    margin-top: auto;
    width: 100%;
  }

  .bargain-btn-quick {
    width: 100%;
    padding: 0.65rem;
    font-size: 0.8rem;
    border-color: rgba(230, 209, 172, 0.1);
  }

  .bargain-bin-cta {
    text-align: center;
  }

  .bargain-view-all-btn {
    padding: 1rem 2rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Bargain Bin Teaser",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Title",
      "default": "Bargain Bin Deals"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading Text",
      "default": "Grab top-tier hardware, glass, and accessory close-outs before they're gone forever."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Bargain Bin Collection"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Label",
      "default": "Shop the Bargain Bin"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Bargain Bin Link"
    }
  ],
  "presets": [
    {
      "name": "Bargain Bin Teaser Strip",
      "category": "Collection"
    }
  ]
}
{% endschema %}
